generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Core ────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  assignedTasks CadenceTask[] @relation("TaskAssignee")
  assignedLeads Lead[] @relation("LeadOwner")

  @@map("users")
}

model Contact {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  company   String?
  createdAt DateTime @default(now()) @map("created_at")

  enrollments CadenceEnrollment[]

  @@map("contacts")
}

// ── Leads ───────────────────────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  source    String?
  status    LeadStatus @default(NEW)
  ownerId   String?  @map("owner_id")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner     User?    @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities LeadActivity[]

  @@index([ownerId, status])
  @@index([status])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  type      ActivityType
  subject   String?
  body      String?
  createdAt DateTime @default(now()) @map("created_at")

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_activities")
}

enum ActivityType {
  NOTE
  EMAIL
  CALL
  MEETING
  TASK
}

// ── Cadence Engine ──────────────────────────────────────

model Cadence {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  steps       CadenceStep[]
  enrollments CadenceEnrollment[]

  @@map("cadences")
}

model CadenceStep {
  id           String @id @default(cuid())
  cadenceId    String @map("cadence_id")
  sortOrder    Int    @map("sort_order")
  name         String

  // timing
  delayMinutes Int    @map("delay_minutes")
  // delay is relative to previous step; step 0 fires immediately on enrollment

  // channel
  channel      CadenceChannel

  // template
  subject      String?
  bodyTemplate String  @map("body_template")
  // {{contact.name}}, {{contact.company}}, etc.

  cadence      Cadence @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  enrollments  CadenceEnrollment[]
  tasks        CadenceTask[]

  @@unique([cadenceId, sortOrder])
  @@map("cadence_steps")
}

enum CadenceChannel {
  EMAIL
  CALL
  SMS
  LINKEDIN
}

model CadenceEnrollment {
  id           String   @id @default(cuid())
  cadenceId    String   @map("cadence_id")
  contactId    String   @map("contact_id")
  currentStepId String? @map("current_step_id")
  status       EnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime @default(now()) @map("enrolled_at")
  completedAt  DateTime? @map("completed_at")

  cadence      Cadence  @relation(fields: [cadenceId], references: [id], onDelete: Restrict)
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Restrict)
  currentStep  CadenceStep? @relation(fields: [currentStepId], references: [id])
  tasks        CadenceTask[]

  @@unique([cadenceId, contactId])
  @@map("cadence_enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  UNENROLLED
}

model CadenceTask {
  id           String   @id @default(cuid())
  enrollmentId String   @map("enrollment_id")
  stepId       String   @map("step_id")
  assigneeId   String?  @map("assignee_id")

  title        String
  body         String?
  channel      CadenceChannel
  dueAt        DateTime @map("due_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  enrollment   CadenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step         CadenceStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  assignee     User?             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([assigneeId, dueAt])
  @@index([enrollmentId])
  @@map("cadence_tasks")
}